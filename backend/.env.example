# DataBridge Backend Environment Variables

# Server
PORT=3008
NODE_ENV=development

# DataBridge Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=databridge_db
DB_USER=databridge
DB_PASSWORD=

# Shared Database (pricelab_db - read-only for sku_master)
SHARED_DB_HOST=localhost
SHARED_DB_PORT=5432
SHARED_DB_NAME=pricelab_db
SHARED_DB_USER=pricelab
SHARED_DB_PASSWORD=

# SSO
SSO_VERIFY_URL=https://apps.iwa.web.tr/api/auth/verify
SSO_APP_CODE=databridge

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3008

# Internal API key (sync trigger endpoint icin)
# Generate: openssl rand -hex 32
# Bu key olmadan /api/v1/sync/* endpoint'leri 503 doner.
INTERNAL_API_KEY=

# Credential encryption key (Wisersell/Wayfair API password'leri AES-256-GCM)
# Generate: openssl rand -hex 32
# 64-char hex (32 byte) zorunlu — eksikse uygulama baslamaz.
CREDENTIAL_ENCRYPTION_KEY=

# Wisersell credentials are managed via Settings UI (stored in DB, encrypted with CREDENTIAL_ENCRYPTION_KEY)
